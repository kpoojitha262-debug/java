public class ArrayFrequency {
    public static void main(String[] args) {

        int arr[] = {11, 32, 81, 87, 81, 48, 32, 81};

        int search = 81;

        int count = 0;

        for(int i = 0; i < arr.length; i++) {

            if(arr[i] == search) {

                count++;
            }
        }

        System.out.println("Frequency of " + search + " = " + count);
    }
}
