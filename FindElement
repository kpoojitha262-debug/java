public class FindElement {
public static void main(String[] args) {
	int arr[] = {1,2,3,4,14,5};
	int search = 14;
	
	boolean found = false;
	
	for(int i = 0; i< arr.length;i++) {
		
		if(arr[i] == search) {
			System.out.println("Element Found at index "+ i);
			found = true;
			break;
		}
	}
	
	if(!found) {
		System.out.println("Element Not Found");
	}
}
}
