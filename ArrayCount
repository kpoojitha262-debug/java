public class ArrayCount {
public static void main(String[] args) {
	int a[] = {15,25,98,75,66,30,64,28,16};
	int evenCount = 0;
	int oddCount = 0;
	for(int i = 0; i< a.length;i++) {
		
	if (a[i] % 2 == 0) {
		evenCount++;
	}
	else {
		oddCount++;
	}
}
	System.out.println("EvenCount:" + evenCount);
	System.out.println("OddCount: " +oddCount);
}
}
