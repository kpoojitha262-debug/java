public class Insurance {
static double calculatePremium(int years,double premium) {
	if (years == 0) {
		return premium;
	}
	premium = premium + (premium*0.05);
	      return calculatePremium(years-1,premium);
}
public static void main(String[] args) {
	double result = calculatePremium(3,5000);
	System.out.println("Premium after 3 Years: "+result);
}
}
